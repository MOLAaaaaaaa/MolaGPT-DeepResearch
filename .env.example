# MolaGPT Deep Research Core - 环境变量配置
#
# 将此文件复制为 .env 并填入您的实际 API 密钥和配置。
# 应用程序会优先使用这些环境变量，而不是 config/config.php 中的值。
# 此 .env 文件应该添加到您的 .gitignore 中以保护您的密钥安全。

# --- 搜索 API 配置 (Exa) ---
# 从 https://exa.ai/ 获取您的密钥
EXA_API_KEY="your-exa-api-key"

# --- 分析 API 配置 (DashScope / OpenAI) ---
# 选择您的提供商: 'dashscope' 或 'openai'
ANALYSIS_PROVIDER="dashscope"

# DashScope API 密钥 (从 https://help.aliyun.com/document_detail/2512515.html 获取)
DASHSCOPE_API_KEY="your-dashscope-api-key"
DASHSCOPE_MODEL="qwen-plus"

# OpenAI API 密钥 (从 https://platform.openai.com/api-keys 获取)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# --- 工具规划器 API 配置 (可选，用于高级工具使用) ---
# 默认使用 OpenRouter，但可以是任何兼容 OpenAI 的 API。
# 从 https://openrouter.ai/keys 获取您的密钥
PLANNER_API_KEY="your-openrouter-api-key"
PLANNER_API_URL="https://openrouter.ai/api/v1/chat/completions"
PLANNER_MODEL="nous-hermes-2-mixtral-8x7b-dpo"

# --- 内容提取器服务 (可选) ---
# 内容读取器 API 服务的 URL。
# 如果您运行 `services/` 目录中提供的 Docker 服务，默认 URL 是正确的。
# 留空以禁用"读取 URL"工具。
READER_API_URL="http://127.0.0.1:8000/read"

# --- 日志配置 ---
LOG_ENABLED=true
# 使用绝对路径或相对于项目根目录的路径。
LOG_FILE_PATH="logs/deep_research.log"

# --- 研究配置 ---
DEFAULT_RESEARCH_DEPTH=3
